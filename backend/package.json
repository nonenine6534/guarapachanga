{
  "name": "la-guarapachanga-backend",
  "version": "1.0.0",
  "description": "Backend para La Guarapachanga - Bar & Licores",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build": "pkg server.js --targets node18-win-x64 --output ../release/LaGuarapachanga.exe"
  },
  "dependencies": {
    "express": "^4.18.2",
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "dotenv": "^16.3.1",
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": [
      "node_modules/sql.js/dist/sql-wasm.wasm",
      "../dist/**/*",
      ".env"
    ],
    "targets": ["node18-win-x64"]
  }
}
